<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
    <display-name>Student Portfolio Manager</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>HelloServlet</servlet-name>
        <servlet-class>com.esma.webtech.servlet.HelloServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HelloServlet</servlet-name>
        <url-pattern>/api/hello</url-pattern>
    </servlet-mapping>
    <servlet>
    <servlet-name>StudentServlet</servlet-name>
    <servlet-class>com.esma.webtech.servlet.StudentServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>StudentServlet</servlet-name>
    <url-pattern>/api/student</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>SkillsServlet</servlet-name>
    <servlet-class>com.esma.webtech.servlet.SkillsServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>SkillsServlet</servlet-name>
    <url-pattern>/api/skills</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>ExperienceServlet</servlet-name>
    <servlet-class>com.esma.webtech.servlet.ExperienceServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ExperienceServlet</servlet-name>
    <url-pattern>/api/experience</url-pattern>
</servlet-mapping>
</web-app>